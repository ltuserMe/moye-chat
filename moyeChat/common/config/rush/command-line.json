{
  "$schema": "https://developer.microsoft.com/json-schemas/rush/v5/command-line.schema.json",
  "commands": [
    {
      "commandKind": "bulk",
      "name": "typecheck",
      "summary": "Type-check all projects.",
      "description": "Runs each project's typecheck script according to Rush dependency order.",
      "safeForSimultaneousRushProcesses": false,
      "enableParallelism": true,
      "ignoreDependencyOrder": false,
      "ignoreMissingScript": false,
      "allowWarningsInSuccessfulBuild": false,
      "incremental": true
    },
    {
      "commandKind": "bulk",
      "name": "lint",
      "summary": "Lint all projects.",
      "description": "Runs each project's lint script according to Rush dependency order.",
      "safeForSimultaneousRushProcesses": false,
      "enableParallelism": true,
      "ignoreDependencyOrder": false,
      "ignoreMissingScript": false,
      "allowWarningsInSuccessfulBuild": false,
      "incremental": true
    }
  ],
  "parameters": []
}
