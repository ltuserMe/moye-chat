{
  "name": "@agent-chat/ui-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --external react --external react-dom",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-chat/chat-core": "workspace:*",
    "@heroicons/react": "^2.2.0",
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.10.0",
    "@lobehub/ui": "^5.15.16",
    "antd": "^6.0.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "tsup": "^8.5.0",
    "typescript": "~6.0.3"
  }
}
