{
  "name": "@agent-chat/chat-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-chat/types": "workspace:*",
    "@agent-chat/utils": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "~6.0.3"
  }
}
